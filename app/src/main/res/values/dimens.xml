<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ==================== -->
    <!-- Android TV Layout System -->
    <!-- Based on TV design guidelines: 48dp margins, proper spacing -->
    <!-- ==================== -->

    <!-- Screen Safe Margins (TV: avoid content too close to edge) -->
    <dimen name="screen_margin_horizontal">48dp</dimen>
    <dimen name="screen_margin_vertical">32dp</dimen>
    <dimen name="screen_edge_padding">48dp</dimen>

    <!-- Sidebar/Lane Dimensions -->
    <dimen name="sidebar_width">200dp</dimen>
    <dimen name="sidebar_padding">24dp</dimen>
    <dimen name="fastlane_width">240dp</dimen>
    <dimen name="vertical_tabs_width">200dp</dimen>

    <!-- Section Spacing -->
    <dimen name="section_spacing">32dp</dimen>
    <dimen name="row_spacing">24dp</dimen>
    <dimen name="card_spacing">16dp</dimen>

    <!-- Card Dimensions -->
    <dimen name="channel_card_width">320dp</dimen>
    <dimen name="channel_card_height">200dp</dimen>
    <dimen name="channel_card_corner_radius">12dp</dimen>
    <dimen name="channel_card_elevation">4dp</dimen>
    <dimen name="channel_card_margin">12dp</dimen>
    <dimen name="channel_logo_size">200dp</dimen>
    <dimen name="gradient_overlay_height">100dp</dimen>

    <!-- Grid Settings -->
    <dimen name="grid_item_width">280dp</dimen>
    <dimen name="grid_item_height">180dp</dimen>
    <dimen name="grid_spacing">20dp</dimen>
    <dimen name="grid_padding">24dp</dimen>

    <!-- Settings Card -->
    <dimen name="settings_card_width">240dp</dimen>
    <dimen name="settings_card_height">160dp</dimen>
    <dimen name="settings_icon_size">64dp</dimen>

    <!-- Header/Divider -->
    <dimen name="header_height">80dp</dimen>
    <dimen name="header_padding">24dp</dimen>
    <dimen name="divider_height">1dp</dimen>
    <dimen name="source_bar_height">64dp</dimen>
    <dimen name="category_tabs_height">56dp</dimen>

    <!-- Text Sizes (TV: larger for distance viewing) -->
    <dimen name="text_title_large">32sp</dimen>
    <dimen name="text_title_medium">28sp</dimen>
    <dimen name="text_title_small">24sp</dimen>
    <dimen name="text_body_large">22sp</dimen>
    <dimen name="text_body_medium">20sp</dimen>
    <dimen name="text_body_small">18sp</dimen>
    <dimen name="text_label">16sp</dimen>

    <!-- Touch Target (minimum 48dp for TV D-pad navigation) -->
    <dimen name="touch_target_min">48dp</dimen>
    <dimen name="button_min_width">88dp</dimen>
    <dimen name="button_height">48dp</dimen>

    <!-- Focus/Padding -->
    <dimen name="focus_padding">8dp</dimen>
    <dimen name="content_padding">16dp</dimen>
    <dimen name="item_padding">12dp</dimen>

    <!-- Icon Sizes -->
    <dimen name="icon_small">24dp</dimen>
    <dimen name="icon_medium">32dp</dimen>
    <dimen name="icon_large">48dp</dimen>
    <dimen name="icon_xlarge">64dp</dimen>

    <!-- Play Icon -->
    <dimen name="play_icon_size">64dp</dimen>

    <!-- Focus Animation Scale - 符合 TV Design Guide 1.025x-1.1x 范围 -->
    <dimen name="card_focus_scale">1.05</dimen>
</resources>
