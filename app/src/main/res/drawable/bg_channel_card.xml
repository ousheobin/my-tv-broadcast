<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_pressed_bg" />
            <stroke android:width="2dp" android:color="@color/focus_pressed_stroke" />
            <corners android:radius="@dimen/channel_card_corner_radius" />
        </shape>
    </item>
    <!-- 聚焦状态: 轮廓指示器 - 3dp primary色边框 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_focused_bg" />
            <stroke android:width="3dp" android:color="@color/primary" />
            <corners android:radius="@dimen/channel_card_corner_radius" />
        </shape>
    </item>
    <!-- 选中状态: 保持聚焦效果 -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_focused_bg" />
            <stroke android:width="3dp" android:color="@color/primary" />
            <corners android:radius="@dimen/channel_card_corner_radius" />
        </shape>
    </item>
    <!-- 默认状态: 暗色表面 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_background" />
            <corners android:radius="@dimen/channel_card_corner_radius" />
        </shape>
    </item>
</selector>
