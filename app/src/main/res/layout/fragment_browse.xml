<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FF000000">

    <!-- Left: Categories -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categories_recycler"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:background="#FF1A1A1A"
        android:padding="8dp"
        android:focusable="true"
        android:descendantFocusability="afterDescendants"
        android:nextFocusRight="@id/channels_recycler"
        android:nextFocusUp="@id/source_bar" />

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#FF2A2A2A" />

    <!-- Right: Channels -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channels_recycler"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:focusable="true"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@id/categories_recycler"
        android:nextFocusUp="@id/source_bar" />

</LinearLayout>
