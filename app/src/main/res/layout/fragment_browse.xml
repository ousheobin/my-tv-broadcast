<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Sources List Container (horizontal) -->
    <LinearLayout
        android:id="@+id/sources_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/category_tabs_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_margin_horizontal"
        android:paddingEnd="@dimen/screen_margin_horizontal"
        android:background="@color/background">

        <HorizontalScrollView
            android:id="@+id/sources_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/sources_list"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:descendantFocusability="afterDescendants"
                    android:focusable="false"
                    android:orientation="horizontal" />

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Channels Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channels_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/screen_margin_horizontal"
        android:paddingEnd="@dimen/screen_margin_horizontal"
        android:paddingTop="0dp"
        android:paddingBottom="@dimen/screen_margin_vertical"
        android:clipToPadding="false"
        android:focusable="true"
        android:descendantFocusability="afterDescendants" />

</LinearLayout>
