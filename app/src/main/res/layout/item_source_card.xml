<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="@dimen/content_padding"
    android:paddingBottom="@dimen/content_padding"
    android:paddingStart="@dimen/header_padding"
    android:paddingEnd="@dimen/header_padding"
    android:background="@drawable/bg_source_card"
    android:focusable="false"
    android:clickable="false">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:focusable="false">

        <TextView
            android:id="@+id/source_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title_small"
            android:maxLines="1"
            android:ellipsize="end"
            android:focusable="false" />

        <TextView
            android:id="@+id/source_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body_small"
            android:maxLines="1"
            android:ellipsize="middle"
            android:layout_marginTop="4dp"
            android:focusable="false" />

    </LinearLayout>

    <TextView
        android:id="@+id/toggle_text"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/touch_target_min"
        android:text="切换"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body_small"
        android:paddingStart="@dimen/content_padding"
        android:paddingEnd="@dimen/content_padding"
        android:gravity="center"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:nextFocusLeft="@id/toggle_text"
        android:nextFocusRight="@id/delete_text"
        android:background="@drawable/bg_tv_button_focus" />

    <TextView
        android:id="@+id/delete_text"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/touch_target_min"
        android:text="删除"
        android:textColor="@color/error"
        android:textSize="@dimen/text_body_small"
        android:paddingStart="@dimen/content_padding"
        android:paddingEnd="@dimen/content_padding"
        android:gravity="center"
        android:layout_marginStart="@dimen/item_padding"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:nextFocusLeft="@id/toggle_text"
        android:background="@drawable/bg_tv_delete_focus" />

</LinearLayout>
